<Window
    x:Class="LineCast.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LineCast"
    MinWidth="1040" MinHeight="680"
    Width="1140" Height="760"
    WindowStartupLocation="CenterScreen"
    Background="#101216"
    Foreground="#eef2f7">

    <Window.Resources>

        <!-- ══ ComboBox full dark restyle ══════════════════════════════════ -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Border Background="#0f1720" BorderBrush="#303846" BorderThickness="1" CornerRadius="7">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="28"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="1" Background="Transparent">
                        <Path HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M 0 0 L 4 4 L 8 0 Z"
                              Fill="#98a2b3"/>
                    </Border>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0f1720"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="DarkComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton x:Name="ToggleButton"
                              Template="{StaticResource DarkComboBoxToggle}"
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                          RelativeSource={RelativeSource TemplatedParent}}"
                              Focusable="False"/>
                <ContentPresenter x:Name="ContentSite"
                                  IsHitTestVisible="False"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                  Margin="10,0,30,0"
                                  VerticalAlignment="Center"/>
                <TextBox x:Name="PART_EditableTextBox"
                         Visibility="Hidden" IsReadOnly="True"
                         Focusable="False" Background="Transparent"
                         Foreground="#f8fafc" CaretBrush="#f8fafc"/>
                <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                    <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                          MinWidth="{TemplateBinding ActualWidth}" MaxHeight="280">
                        <Border Background="#11151b" BorderBrush="#334155" BorderThickness="1" CornerRadius="0,0,7,7">
                            <ScrollViewer SnapsToDevicePixels="True">
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Popup>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#3f4b5f"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Template"        Value="{StaticResource DarkComboBoxTemplate}"/>
            <Setter Property="Background"      Value="#0f1720"/>
            <Setter Property="Foreground"      Value="#f8fafc"/>
            <Setter Property="BorderBrush"     Value="#303846"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight"       Value="34"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="FontSize"        Value="10"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="#eef2f7"/>
            <Setter Property="Padding"     Value="10,7"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1f2937"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0ea5e9"/>
                                <Setter Property="Foreground" Value="#06121f"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Button ══════════════════════════════════════════════════════ -->
        <Style TargetType="Button">
            <Setter Property="Background"      Value="#232a36"/>
            <Setter Property="Foreground"      Value="#f8fafc"/>
            <Setter Property="BorderBrush"     Value="#354052"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight"       Value="34"/>
            <Setter Property="Padding"         Value="13,0"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2c3544"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#475569"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1d2430"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"  Value="#0ea5e9"/>
            <Setter Property="BorderBrush" Value="#38bdf8"/>
            <Setter Property="Foreground"  Value="#06121f"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#38bdf8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"  Value="#3a2028"/>
            <Setter Property="BorderBrush" Value="#7f1d1d"/>
            <Setter Property="Foreground"  Value="#fecaca"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4a2530"/>
                    <Setter Property="BorderBrush" Value="#ef4444"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ══ CheckBox dark restyle ═══════════════════════════════════════ -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#cbd5e1"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Box" Width="18" Height="18"
                                    Background="#0f1720" BorderBrush="#303846"
                                    BorderThickness="1" CornerRadius="5"
                                    Margin="0,0,8,0">
                                <Path x:Name="Check"
                                      Data="M 2 9 L 7 14 L 16 3"
                                      Stroke="#22c55e" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Box"   Property="BorderBrush" Value="#86efac"/>
                                <Setter TargetName="Box"   Property="Background"  Value="#052e16"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#38bdf8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Slider dark restyle ═════════════════════════════════════════ -->
        <Style TargetType="Slider">
            <Setter Property="Minimum"           Value="0"/>
            <Setter Property="Maximum"           Value="100"/>
            <Setter Property="SmallChange"       Value="1"/>
            <Setter Property="LargeChange"       Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="#22c55e" Height="6" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="#29313d" Height="6" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="16" Height="16"
                                                         Fill="#f8fafc"
                                                         Stroke="#22c55e"
                                                         StrokeThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ TextBox ═════════════════════════════════════════════════════ -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#0f1720"/>
            <Setter Property="Foreground"      Value="#f8fafc"/>
            <Setter Property="BorderBrush"     Value="#303846"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight"       Value="34"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="CaretBrush"      Value="#f8fafc"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#38bdf8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#3f4b5f"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ GroupBox ════════════════════════════════════════════════════ -->
        <Style TargetType="GroupBox">
            <Setter Property="Background"      Value="#181b21"/>
            <Setter Property="BorderBrush"     Value="#2a3039"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#f8fafc"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="14,10,14,14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Grid.RowSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"/>
                            <TextBlock Grid.Row="0"
                                       Text="{TemplateBinding Header}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       FontSize="10"
                                       Margin="14,8,0,0"/>
                            <ContentPresenter Grid.Row="1"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ DataGrid ════════════════════════════════════════════════════ -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="#11151b"/>
            <Setter Property="Foreground"               Value="#e5e7eb"/>
            <Setter Property="BorderBrush"              Value="#29313d"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="RowBackground"            Value="#11151b"/>
            <Setter Property="AlternatingRowBackground" Value="#151a22"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#202732"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="SelectionUnit"            Value="FullRow"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="CanUserReorderColumns"    Value="False"/>
            <Setter Property="CanUserResizeRows"        Value="False"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="FontSize"                 Value="10"/>
            <Setter Property="RowHeight"                Value="38"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"  Value="#1d2430"/>
            <Setter Property="Foreground"  Value="#aab6c5"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Padding"     Value="10,8"/>
            <Setter Property="BorderBrush" Value="#2a3039"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#123c55"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1a2535"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="8,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ══ ScrollBar ═══════════════════════════════════════════════════ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#11151b"/>
            <Setter Property="Width"      Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#334155"
                                                        CornerRadius="5"
                                                        Margin="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="#101216">
        <Grid Margin="16,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Top bar ─────────────────────────────────────────────── -->
            <Border Grid.Row="0" Background="#161a22" BorderBrush="#2a3039"
                    BorderThickness="1" CornerRadius="8"
                    Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="LineCast" FontSize="20" FontWeight="Bold"
                               Foreground="#f8fafc" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="#1f2937"
                            BorderBrush="#334155" BorderThickness="1"
                            CornerRadius="8" Padding="11,7">
                        <TextBlock x:Name="StatusLabel" Text="Ready"
                                   Foreground="#dbeafe" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Audio Routing ───────────────────────────────────────── -->
            <GroupBox Grid.Row="1" Header="Audio Routing" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Monitor Device"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,5"/>
                    <ComboBox  Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                               x:Name="MonitorCombo" Margin="0,5" DisplayMemberPath="Name"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Monitor Volume"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,5"/>
                    <Slider    Grid.Row="1" Grid.Column="1" x:Name="MonitorSlider"
                               Minimum="0" Maximum="100" Value="85" Margin="0,5"
                               ValueChanged="OnVolumeChanged"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" x:Name="MonitorValueLabel"
                               Text="85%" Foreground="#cbd5e1"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Mic Input"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,5"/>
                    <ComboBox  Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                               x:Name="MicCombo" Margin="0,5" DisplayMemberPath="Name"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Mic Volume"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,5"/>
                    <Slider    Grid.Row="3" Grid.Column="1" x:Name="MicSlider"
                               Minimum="0" Maximum="100" Value="85" Margin="0,5"
                               ValueChanged="OnVolumeChanged"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" x:Name="MicValueLabel"
                               Text="85%" Foreground="#cbd5e1"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <CheckBox  Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                               x:Name="MicPassthroughCheck"
                               Content="Mix mic into virtual input"
                               IsChecked="True" Margin="0,5"
                               Checked="OnMicPassthroughChanged"
                               Unchecked="OnMicPassthroughChanged"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Device/App Audio Source"
                               Foreground="#98a2b3" VerticalAlignment="Center"
                               Margin="0,5" TextWrapping="Wrap"/>
                    <ComboBox  Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                               x:Name="ExternalAudioCombo" Margin="0,5" DisplayMemberPath="Name"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Device/App Volume"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,5"/>
                    <Slider    Grid.Row="6" Grid.Column="1" x:Name="ExternalAudioSlider"
                               Minimum="0" Maximum="100" Value="85" Margin="0,5"
                               ValueChanged="OnVolumeChanged"/>
                    <TextBlock Grid.Row="6" Grid.Column="2" x:Name="ExternalAudioValueLabel"
                               Text="85%" Foreground="#cbd5e1"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <CheckBox  Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2"
                               x:Name="ExternalAudioCheck"
                               Content="Mix device/app audio into virtual input"
                               IsChecked="False" Margin="0,5"
                               Checked="OnExternalAudioChanged"
                               Unchecked="OnExternalAudioChanged"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Injection Device"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,5"/>
                    <ComboBox  Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2"
                               x:Name="InjectionCombo" Margin="0,5" DisplayMemberPath="Name"/>

                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Sound Injection Volume"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,5"/>
                    <Slider    Grid.Row="9" Grid.Column="1" x:Name="InjectionSlider"
                               Minimum="0" Maximum="100" Value="85" Margin="0,5"
                               ValueChanged="OnVolumeChanged"/>
                    <TextBlock Grid.Row="9" Grid.Column="2" x:Name="InjectionValueLabel"
                               Text="85%" Foreground="#cbd5e1"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <CheckBox  Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2"
                               x:Name="AdvancedDevicesCheck"
                               Content="Show advanced audio devices"
                               IsChecked="False" Margin="0,5"
                               Checked="OnAdvancedDevicesChanged"
                               Unchecked="OnAdvancedDevicesChanged"/>
                </Grid>
            </GroupBox>

            <!-- ── Sound Library ───────────────────────────────────────── -->
            <Border Grid.Row="2" Background="#181b21" BorderBrush="#2a3039"
                    BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Controls bar -->
                    <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="SearchBox" Width="200" Margin="0,0,10,4"
                                 TextChanged="OnSearchChanged"/>
                        <Button Content="Add Sounds"  Margin="0,0,6,4" Click="OnAddSounds"/>
                        <Button Content="Rename"      Margin="0,0,6,4" Click="OnRenameSound"/>
                        <Button Content="Change Path" Margin="0,0,6,4" Click="OnChangePath"/>
                        <Button Content="Delete"      Margin="0,0,6,4"
                                Style="{StaticResource DangerButton}" Click="OnDeleteSound"/>
                        <Button Content="▶  Play"     Margin="0,0,6,4"
                                Style="{StaticResource PrimaryButton}" Click="OnPlay"/>
                        <Button Content="■  Stop"     Margin="0,0,0,4"
                                Style="{StaticResource DangerButton}" Click="OnStop"/>
                    </WrapPanel>

                    <!-- Review slider -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Review" Foreground="#98a2b3"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Slider Grid.Column="1" x:Name="ReviewSlider"
                                Minimum="0" Maximum="0" IsEnabled="False"
                                Margin="0,0,10,0"
                                MouseLeftButtonDown="OnReviewSliderPressed"
                                MouseLeftButtonUp="OnReviewSliderReleased"/>
                        <TextBlock Grid.Column="2" x:Name="ReviewTimeLabel"
                                   Text="00:00 / 00:00" Foreground="#cbd5e1"
                                   VerticalAlignment="Center" MinWidth="95"/>
                    </Grid>

                    <!-- Sound table -->
                    <DataGrid Grid.Row="2" x:Name="SoundTable" MinHeight="170"
                              MouseDoubleClick="OnTableDoubleClick"
                              SelectionChanged="OnTableSelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sound"
                                                Binding="{Binding Name}"
                                                Width="Auto" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Path"
                                                Binding="{Binding Path}"
                                                Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

        </Grid>
    </ScrollViewer>
</Window>
