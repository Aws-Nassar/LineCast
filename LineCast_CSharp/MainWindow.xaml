<Window
    x:Class="LineCast.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LineCast"
    MinWidth="1040" MinHeight="680"
    Width="1140" Height="760"
    WindowStartupLocation="CenterScreen"
    Background="#101216"
    Foreground="#eef2f7">

    <Window.Resources>

        <!-- ── Colours ─────────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgDeep"        Color="#101216"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#181b21"/>
        <SolidColorBrush x:Key="BgInput"       Color="#0f1720"/>
        <SolidColorBrush x:Key="BorderNormal"  Color="#2a3039"/>
        <SolidColorBrush x:Key="BorderFocus"   Color="#38bdf8"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#f8fafc"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#98a2b3"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#0ea5e9"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#22c55e"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#ef4444"/>

        <!-- ── ComboBox ────────────────────────────────────────────────────── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"          Value="#0f1720"/>
            <Setter Property="Foreground"          Value="#f8fafc"/>
            <Setter Property="BorderBrush"         Value="#303846"/>
            <Setter Property="BorderThickness"     Value="1"/>
            <Setter Property="MinHeight"           Value="34"/>
            <Setter Property="Padding"             Value="8,0"/>
            <Setter Property="FontSize"            Value="10"/>
        </Style>

        <!-- ── Button base ────────────────────────────────────────────────── -->
        <Style TargetType="Button">
            <Setter Property="Background"      Value="#232a36"/>
            <Setter Property="Foreground"      Value="#f8fafc"/>
            <Setter Property="BorderBrush"     Value="#354052"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight"       Value="34"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2c3544"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1d2430"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Primary (blue) button ──────────────────────────────────────── -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"  Value="#0ea5e9"/>
            <Setter Property="BorderBrush" Value="#38bdf8"/>
            <Setter Property="Foreground"  Value="#06121f"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#38bdf8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Danger (red) button ────────────────────────────────────────── -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"  Value="#3a2028"/>
            <Setter Property="BorderBrush" Value="#7f1d1d"/>
            <Setter Property="Foreground"  Value="#fecaca"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4a2530"/>
                    <Setter Property="BorderBrush" Value="#ef4444"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── CheckBox ───────────────────────────────────────────────────── -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#cbd5e1"/>
            <Setter Property="FontSize"   Value="10"/>
        </Style>

        <!-- ── Slider ─────────────────────────────────────────────────────── -->
        <Style TargetType="Slider">
            <Setter Property="Minimum"         Value="0"/>
            <Setter Property="Maximum"         Value="100"/>
            <Setter Property="SmallChange"     Value="1"/>
            <Setter Property="LargeChange"     Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ── TextBox ────────────────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#0f1720"/>
            <Setter Property="Foreground"      Value="#f8fafc"/>
            <Setter Property="BorderBrush"     Value="#303846"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight"       Value="34"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── DataGrid ───────────────────────────────────────────────────── -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"            Value="#11151b"/>
            <Setter Property="Foreground"            Value="#e5e7eb"/>
            <Setter Property="BorderBrush"           Value="#29313d"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="RowBackground"         Value="#11151b"/>
            <Setter Property="AlternatingRowBackground" Value="#151a22"/>
            <Setter Property="GridLinesVisibility"   Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#202732"/>
            <Setter Property="SelectionMode"         Value="Single"/>
            <Setter Property="SelectionUnit"         Value="FullRow"/>
            <Setter Property="AutoGenerateColumns"   Value="False"/>
            <Setter Property="CanUserAddRows"        Value="False"/>
            <Setter Property="CanUserDeleteRows"     Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserResizeRows"     Value="False"/>
            <Setter Property="HeadersVisibility"     Value="Column"/>
            <Setter Property="FontSize"              Value="10"/>
            <Setter Property="RowHeight"             Value="38"/>
        </Style>

    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="16,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Top bar ───────────────────────────────────────────────── -->
            <Border Grid.Row="0" Background="#161a22" BorderBrush="#2a3039"
                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="LineCast" FontSize="20" FontWeight="Bold"
                               Foreground="#f8fafc" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="#1f2937" BorderBrush="#334155"
                            BorderThickness="1" CornerRadius="8" Padding="11,7">
                        <TextBlock x:Name="StatusLabel" Text="Ready"
                                   Foreground="#dbeafe" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Audio Routing group ────────────────────────────────────── -->
            <GroupBox Grid.Row="1" Header="Audio Routing" Margin="0,0,0,10"
                      Background="#181b21" BorderBrush="#2a3039"
                      Foreground="#f8fafc" FontWeight="Bold">
                <Grid Margin="4,4,4,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Monitor Device -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Monitor Device"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,4"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                              x:Name="MonitorCombo" Margin="0,4" DisplayMemberPath="Name"/>

                    <!-- Monitor Volume -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Monitor Volume"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,4"/>
                    <Slider Grid.Row="1" Grid.Column="1" x:Name="MonitorSlider" Margin="0,4"
                            Value="85" ValueChanged="OnVolumeChanged"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" x:Name="MonitorValueLabel"
                               Text="85%" Foreground="#cbd5e1" VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <!-- Mic Input -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Mic Input"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,4"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                              x:Name="MicCombo" Margin="0,4" DisplayMemberPath="Name"/>

                    <!-- Mic Volume -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Mic Volume"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,4"/>
                    <Slider Grid.Row="3" Grid.Column="1" x:Name="MicSlider" Margin="0,4"
                            Value="85" ValueChanged="OnVolumeChanged"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" x:Name="MicValueLabel"
                               Text="85%" Foreground="#cbd5e1" VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <!-- Mic passthrough -->
                    <CheckBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                              x:Name="MicPassthroughCheck"
                              Content="Mix mic into virtual input"
                              IsChecked="True" Margin="0,4"
                              Checked="OnMicPassthroughChanged"
                              Unchecked="OnMicPassthroughChanged"/>

                    <!-- External audio source -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Device/App Audio Source"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,4"
                               TextWrapping="Wrap"/>
                    <ComboBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                              x:Name="ExternalAudioCombo" Margin="0,4" DisplayMemberPath="Name"/>

                    <!-- External audio volume -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Device/App Volume"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,4"/>
                    <Slider Grid.Row="6" Grid.Column="1" x:Name="ExternalAudioSlider" Margin="0,4"
                            Value="85" ValueChanged="OnVolumeChanged"/>
                    <TextBlock Grid.Row="6" Grid.Column="2" x:Name="ExternalAudioValueLabel"
                               Text="85%" Foreground="#cbd5e1" VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <!-- External audio enable -->
                    <CheckBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2"
                              x:Name="ExternalAudioCheck"
                              Content="Mix device/app audio into virtual input"
                              IsChecked="False" Margin="0,4"
                              Checked="OnExternalAudioChanged"
                              Unchecked="OnExternalAudioChanged"/>

                    <!-- Injection Device -->
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Injection Device"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,4"/>
                    <ComboBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2"
                              x:Name="InjectionCombo" Margin="0,4" DisplayMemberPath="Name"/>

                    <!-- Injection volume -->
                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Sound Injection Volume"
                               Foreground="#98a2b3" VerticalAlignment="Center" Margin="0,4"/>
                    <Slider Grid.Row="9" Grid.Column="1" x:Name="InjectionSlider" Margin="0,4"
                            Value="85" ValueChanged="OnVolumeChanged"/>
                    <TextBlock Grid.Row="9" Grid.Column="2" x:Name="InjectionValueLabel"
                               Text="85%" Foreground="#cbd5e1" VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <!-- Advanced devices -->
                    <CheckBox Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2"
                              x:Name="AdvancedDevicesCheck"
                              Content="Show advanced audio devices"
                              IsChecked="False" Margin="0,4"
                              Checked="OnAdvancedDevicesChanged"
                              Unchecked="OnAdvancedDevicesChanged"/>
                </Grid>
            </GroupBox>

            <!-- ── Sound library panel ────────────────────────────────────── -->
            <Border Grid.Row="2" Background="#181b21" BorderBrush="#2a3039"
                    BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Controls bar -->
                    <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="SearchBox" Width="200" Margin="0,0,8,0"
                                 Text="" TextChanged="OnSearchChanged"
                                 Tag="Search sounds"/>
                        <Button Content="Add Sounds"   Margin="0,0,6,0" Click="OnAddSounds"/>
                        <Button Content="Rename"       Margin="0,0,6,0" Click="OnRenameSound"/>
                        <Button Content="Change Path"  Margin="0,0,6,0" Click="OnChangePath"/>
                        <Button Content="Delete"       Margin="0,0,6,0"
                                Style="{StaticResource DangerButton}" Click="OnDeleteSound"/>
                        <Button Content="▶  Play"      Margin="0,0,6,0"
                                Style="{StaticResource PrimaryButton}" Click="OnPlay"/>
                        <Button Content="■  Stop"      Margin="0,0,0,0"
                                Style="{StaticResource DangerButton}" Click="OnStop"/>
                    </WrapPanel>

                    <!-- Review slider -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Review" Foreground="#98a2b3"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider Grid.Column="1" x:Name="ReviewSlider" Minimum="0" Maximum="0"
                                IsEnabled="False" Margin="0,0,8,0"
                                PreviewMouseDown="OnReviewSliderPressed"
                                PreviewMouseUp="OnReviewSliderReleased"/>
                        <TextBlock Grid.Column="2" x:Name="ReviewTimeLabel"
                                   Text="00:00 / 00:00" Foreground="#cbd5e1"
                                   VerticalAlignment="Center" MinWidth="92"/>
                    </Grid>

                    <!-- Sound table -->
                    <DataGrid Grid.Row="2" x:Name="SoundTable" MinHeight="170"
                              MouseDoubleClick="OnTableDoubleClick"
                              SelectionChanged="OnTableSelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sound" Binding="{Binding Name}"
                                                Width="Auto" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Path"  Binding="{Binding Path}"
                                                Width="*"    IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

        </Grid>
    </ScrollViewer>
</Window>
